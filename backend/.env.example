# Model provider (choose one)
MODEL_PROVIDER=github
GITHUB_TOKEN=ghp_your_token_here
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-your_key_here
# MODEL_PROVIDER=gemini
# GEMINI_API_KEY=your_key_here
# MODEL_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_openrouter_key_here

# Azure Foundry IQ (Microsoft IQ requirement)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your_key_here
AZURE_SEARCH_INDEX_NAME=thesisdefender-index

# Infrastructure
REDIS_URL=redis://localhost:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ADK integration (Phase 1 — Kaggle Capstone)
# Set to true to route the analysis pipeline through Google ADK SequentialAgent.
# Requires google-adk>=1.0.0 (already in requirements.txt).
# Default: false — original pipeline.py logic runs unchanged.
USE_ADK=false

# MCP Server (Phase 2 — Kaggle Capstone)
# URL of the FastMCP SSE server. Start separately with:
#   cd backend && python -m mcp_server.run_server
# Agents degrade gracefully (no enrichment) if the server is unreachable.
MCP_SERVER_URL=http://localhost:8001/sse
MCP_PORT=8001
